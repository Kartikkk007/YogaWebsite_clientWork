{
  "name": "yoga-website",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspace frontend -- --outDir ../dist --emptyOutDir",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "start": "npm run start --workspace backend"
  },
  "engines": {
    "node": ">=18"
  }
}
